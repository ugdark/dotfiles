# 退避・一時ファイル
.tmp/

# IDE
.idea/

# Claude Code自動生成（ルート直下のみ）
/.claude/

# 会社/環境固有の設定
*.local
# 例外: stowで ~/.local/bin/ にリンクするスクリプト群
!settings/bin/.local/
!settings/bin/.local/**

# ローカル専用（plans, knowledges, links等）
vault/

# Codex が自動生成するマシン固有の状態（trust_level・NUXフラグ等）
settings/codex/.codex/config.toml
