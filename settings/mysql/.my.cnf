# mysql CLI 共通設定（接続情報・パスワードは含めない）
# 接続情報はSequel AceのFavorites.plist + Keychainで管理し、
# このファイルはターミナル使用時のQOL設定だけを担う。

# ============================================================
# [client] : mysql, mysqldump, mysqladmin 等すべてのクライアント共通
# ============================================================
[client]
# 通信文字コードをutf8mb4に固定。
# 絵文字や4バイトUTF-8（𠮷野家の「𠮷」など）を含むデータで文字化けしないため。
# サーバー側がutf8mb4でも、クライアントがlatin1だと結果が化ける。
default-character-set = utf8mb4

# 対話プロンプトを「user@host [db]>」形式に。
# 接続先を取り違えて本番DBに誤クエリ、を防ぐ視覚的ガード。
# 例: root@127.0.0.1 [cel_lem_dev]>
prompt = "\\u@\\h [\\d]> "

# ============================================================
# [mysql] : 対話シェル `mysql` だけに効く設定
# ============================================================
[mysql]
# Tab補完を有効化。テーブル名・カラム名を補完できる。
# 大規模DBだと接続時のメタデータ取得で起動が遅くなる副作用あり。
# その時は `--no-auto-rehash` で起動するか、ここを `no-auto-rehash` に変更。
auto-rehash

# クエリ結果が横長な時、画面幅で横スクロールできるpagerを使う。
# -S: 折り返さない / -F: 1画面に収まるなら即終了 / -X: 終了時に画面クリアしない
# これがないと、横長テーブルが折り返されて読めなくなる。
pager = less -SFX

# クエリ実行後にwarningがあれば自動表示。
# 暗黙の型変換・truncate等を見逃さないため。
# デフォルトでは `SHOW WARNINGS` を別途叩く必要があるが、それを自動化する。
show-warnings

# Ctrl+C を「クエリのみキャンセル」にする（接続は切らない）。
# デフォルトでは Ctrl+C で接続ごと切断されるため、長いクエリの誤爆で切れる事故を防止。
sigint-ignore

# ============================================================
# [mysqldump] : ダンプツール専用
# ============================================================
[mysqldump]
# ダンプ出力もutf8mb4で。
# クライアント側がutf8mb4でもmysqldumpはここを別途見るため明示が必要。
default-character-set = utf8mb4
