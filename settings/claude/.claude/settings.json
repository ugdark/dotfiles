{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Glob",
      "Grep",
      "Bash(*)",
      "Skill",
      "Edit(~/Works/**)",
      "Write(~/Works/**)",
      "Edit(~/.dotfiles/**)",
      "Write(~/.dotfiles/**)",
      "mcp__github__*",
      "mcp__ide__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(git branch -D *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(gh repo delete *)",
      "Bash(gh pr close *)",
      "Bash(gh issue close *)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "language": "japanese",
  "effortLevel": "medium",
  "showThinkingSummaries": false,
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true
}
