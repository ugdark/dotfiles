{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Glob",
      "Grep",
      "Bash(*)",
      "Skill",
      "Edit(~/Works/**)",
      "Edit(~/.dotfiles/**)",
      "mcp__github__*",
      "mcp__ide__*",
      "mcp__chrome-devtools__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(git branch -D *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(gh repo delete *)",
      "Bash(gh pr close *)",
      "Bash(gh issue close *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/secret-guard.sh",
            "if": "Bash(git commit *)",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "language": "japanese",
  "effortLevel": "medium",
  "tui": "fullscreen",
  "showThinkingSummaries": false,
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true
}
